# ============================================================
# Exiv System Configuration Template
# Copy to .env and fill in your values.
# ============================================================

# --- Server ---
PORT=8081
RUST_LOG=info

# --- Security (Principle #5: Strict Permission Isolation) ---
# Admin API key for protected endpoints (plugin config, permissions, shutdown).
# REQUIRED in release builds. Generate with: openssl rand -hex 32
EXIV_API_KEY=

# --- Database ---
# SQLite database path. Parent directory is created automatically at startup.
# DATABASE_URL=sqlite:./data/exiv_memories.db

# --- AI Provider API Keys ---
# DEEPSEEK_API_KEY=
# CEREBRAS_API_KEY=

# --- Consensus (Principle #8: Dynamic Intelligence Orchestration) ---
# CONSENSUS_ENGINES=mind.deepseek,mind.cerebras

# --- Agent ---
# DEFAULT_AGENT_ID=agent.karin

# --- Tuning ---
# MAX_EVENT_DEPTH=10
# PLUGIN_EVENT_TIMEOUT_SECS=30
# MEMORY_CONTEXT_LIMIT=10

# --- Remote Update (Principle #8: HITL) ---
# GitHub repository for update distribution.
# Format: owner/repo (e.g. karin-project/exiv-system)
# EXIV_UPDATE_REPO=karin-project/exiv-system

# --- Network ---
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# ALLOWED_HOSTS=
